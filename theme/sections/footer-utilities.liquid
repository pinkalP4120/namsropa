        <!-- Policy Disclaimer -->
        {% if section.settings.show_policy_disclaimer %}
          <p class="policy-disclaimer">{{ section.settings.policy_disclaimer_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Middle Section: Tagline -->
  {% if section.settings.show_tagline %}
    <div class="footer-tagline">
      <h2 class="tagline-title">{{ section.settings.tagline_title }}</h2>
      <p class="tagline-subtitle">{{ section.settings.tagline_subtitle }}</p>
    </div>
  {% endif %}

  <!-- Bottom Section: Copyright -->
  <div class="footer-copyright">
    <p class="copyright-text">© Copyright {{ 'now' | date: '%Y' }} {{ section.settings.company_name }}</p>
  </div>
</div>

{% stylesheet %}
  .footer-main {
    width: 100%;
    padding: 40px 20px;
    background-color: var(--color-background);
  }

  .footer-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media screen and (min-width: 750px) {
    .footer-content {
      flex-direction: row;
      align-items: flex-start;
      gap: 40px;
    }
  }

  /* Columns Wrapper - All columns in one row */
  .footer-columns-wrapper {
    display: flex;
    flex-direction: column;
    gap: 30px;
    flex: 1;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .footer-columns-wrapper {
      flex-direction: row;
      gap: 30px;
      align-items: flex-start;
      flex-wrap: wrap;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-columns-wrapper {
      flex-wrap: nowrap;
    }
  }

  /* Individual Footer Column */
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1 1 auto;
    min-width: 0;
  }

  @media screen and (min-width: 750px) {
    .footer-column {
      flex: 1 1 calc(50% - 15px);
      min-width: 150px;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-column {
      flex: 1 1 0;
      min-width: 0;
    }
  }

  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-phone,
  .contact-hours {
    font-size: 14px;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  .contact-link {
    font-size: 14px;
    color: var(--color-foreground-muted);
    text-decoration: none;
  }

  .contact-link:hover {
    text-decoration: underline;
  }

  .column-heading {
    font-weight: 700;
    font-size: 16px;
    color: var(--color-foreground);
    margin: 0 0 8px 0;
  }

  .column-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .column-links li {
    margin: 0;
  }

  .column-links a {
    font-size: 14px;
    color: var(--color-foreground-muted);
    text-decoration: none;
    line-height: 1.5;
  }

  .column-links a:hover {
    text-decoration: underline;
  }

  /* Right Section: Social Media, Apps & Policy */
  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .footer-right {
      flex: 0 0 auto;
      min-width: 250px;
      max-width: 300px;
      align-items: flex-start;
    }
  }

  .social-media {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-foreground);
    color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .social-icon:hover {
    opacity: 0.8;
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
    display: block;
  }
  
  .social-icon svg path {
    fill: currentColor;
  }

  .policy-disclaimer {
    font-size: 12px;
    color: var(--color-foreground-muted);
    text-align: center;
    margin: 0;
    line-height: 1.5;
    max-width: 300px;
  }

  @media screen and (min-width: 750px) {
    .policy-disclaimer {
      text-align: left;
      max-width: none;
    }
  }

  /* Middle Section: Tagline */
  .footer-tagline {
    text-align: center;
    padding: 30px 20px;
    background-color: var(--color-background);
  }

  .tagline-title {
    font-weight: 700;
    font-size: 20px;
    color: var(--color-foreground);
    margin: 0 0 8px 0;
  }

  .tagline-subtitle {
    font-size: 16px;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* Bottom Section: Copyright */
  .footer-copyright {
    background-color: var(--color-foreground);
    padding: 20px;
    text-align: center;
  }

  .copyright-text {
    color: var(--color-background);
    font-size: 14px;
    margin: 0;
  }
{% endstylesheet %}

