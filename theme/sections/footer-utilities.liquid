<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  {{ section.shopify_attributes }}
>
  <!-- Main Footer Content -->
  <div class="footer-main" style="{% render 'spacing-style', settings: section.settings %}">
    <div class="footer-content">
      <!-- All Columns in One Row -->
      <div class="footer-columns-wrapper">
        <!-- Contact Us Column -->
        <div class="footer-column footer-column-contact">
          <div class="contact-section">
            <h3 class="column-heading">Contact Us</h3>
            <p class="contact-phone">{{ section.settings.phone_number }}</p>
            <p class="contact-hours">{{ section.settings.hours }}</p>
            <a href="{{ section.settings.contact_link | default: '#' }}" class="contact-link">{{ section.settings.contact_link_text }}</a>
          </div>
        </div>

        <!-- Sales Policy Column -->
        {% if section.settings.show_sales_policy_column %}
          <div class="footer-column">
            <h4 class="column-heading">Sales Policy</h4>
            <ul class="column-links">
              <li><a href="{{ section.settings.sales_policy_link_1_url | default: '#' }}">{{ section.settings.sales_policy_link_1_text }}</a></li>
              <li><a href="{{ section.settings.sales_policy_link_2_url | default: '#' }}">{{ section.settings.sales_policy_link_2_text }}</a></li>
              <li><a href="{{ section.settings.sales_policy_link_3_url | default: '#' }}">{{ section.settings.sales_policy_link_3_text }}</a></li>
            </ul>
          </div>
        {% endif %}

        <!-- Partner Column -->
        {% if section.settings.show_partner_column %}
          <div class="footer-column">
            <h4 class="column-heading">Nam's Updates</h4>
            <ul class="column-links">
              <li><a href="{{ section.settings.partner_link_1_url | default: '#' }}">{{ section.settings.partner_link_1_text }}</a></li>
              <li><a href="{{ section.settings.partner_link_2_url | default: '#' }}">{{ section.settings.partner_link_2_text }}</a></li>
            </ul>
          </div>
        {% endif %}

        <!-- About Column -->
        {% if section.settings.show_about_column %}
          <div class="footer-column">
            <h4 class="column-heading">About</h4>
            <ul class="column-links">
              <li><a href="{{ section.settings.about_link_1_url | default: '#' }}">{{ section.settings.about_link_1_text }}</a></li>
              <li><a href="{{ section.settings.about_link_2_url | default: '#' }}">{{ section.settings.about_link_2_text }}</a></li>
              <li><a href="{{ section.settings.about_link_3_url | default: '#' }}">{{ section.settings.about_link_3_text }}</a></li>
              <li><a href="{{ section.settings.about_link_4_url | default: '#' }}">{{ section.settings.about_link_4_text }}</a></li>
            </ul>
          </div>
        {% endif %}
      </div>

      <!-- Right Section: Social Media, Apps & Policy -->
      <div class="footer-right">
        <!-- Social Media Icons -->
        {% if section.settings.show_social_media %}
          <div class="social-media">
            <a href="{{ section.settings.facebook_url | default: '#' }}" class="social-icon" aria-label="Facebook">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
